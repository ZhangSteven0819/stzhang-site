---
import Header from "../components/Header.astro";
import FeaturedPost from "../components/FeaturedPost.astro";
import PostRow from "../components/PostRow.astro";
import { getPosts } from "../lib/posts";
import "../styles/global.css";

const posts = getPosts();
const featured = posts[0];
const rest = posts.slice(1, 7);
const showViewAll = posts.length > 6;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ST Zhang</title>
    <meta
      name="description"
      content="ST Zhang's personal blog about AI, technology, notes, and building on the internet."
    />
  </head>

  <body>
    <div class="site-shell">
      <Header />

      <main class="page-main">
        <section class="hero">
          <div class="hero-copy">
            <span class="hero-tag">Personal blog</span>
            <h1 class="hero-title" data-no-translate>ST Zhang</h1>
            <p class="hero-subtitle">AI · Tech · Notes</p>
            <p class="hero-desc">
              Writing, building, and thinking on the internet.
            </p>
          </div>

          <aside class="hero-aside" data-no-translate>
            <span class="quote-label" id="daily-quote-label">Daily quote</span>
            <p class="quote-text" id="daily-quote-text">
              The obstacle is the way.
            </p>
            <p class="quote-source" id="daily-quote-source">
              Marcus Aurelius · Meditations
            </p>
          </aside>
        </section>

        <section id="writing" class="writing-section">
          <div class="section-heading">
            <h2>Writing</h2>
            {showViewAll && <a href="/writing">View all →</a>}
          </div>

          {
            featured ? (
              <>
                <FeaturedPost post={featured} />

                {
                  rest.length > 0 && (
                    <div class="post-list">
                      {rest.map((post) => <PostRow post={post} />)}
                    </div>
                  )
                }
              </>
            ) : (
              <p class="empty-state">No posts yet.</p>
            )
          }
        </section>

        <section class="topics-section">
          <div class="section-heading">
            <h2>Topics</h2>
          </div>

          <div class="topic-layout">
            <div class="topic-panel topic-panel-large">
              <h3>AI</h3>
              <p>
                Notes on models, tools, workflows, automation, and how AI changes
                the way people build and think.
              </p>
            </div>

            <div class="topic-stack">
              <div class="topic-panel">
                <h3>Tech</h3>
                <p>
                  Practical writing about software, web infrastructure, domains,
                  deployment, and the small systems behind personal projects.
                </p>
              </div>

              <div class="topic-panel">
                <h3>Notes</h3>
                <p>
                  Short observations, reading notes, decisions, and personal logs
                  that do not need to become polished essays.
                </p>
              </div>
            </div>
          </div>
        </section>
      </main>

      <footer class="site-footer">
        <div class="footer-left">
          <span>© {new Date().getFullYear()} ST Zhang</span>
          <p class="footer-tagline">Writing, building, and thinking on the internet.</p>
        </div>
      </footer>
    </div>

    <script is:inline src="/scripts/i18n.js"></script>
    
    <script is:inline>
      (function() {
        // Only run on non-touch devices
        const isTouchDevice = window.matchMedia('(hover: none)').matches;
        if (isTouchDevice) return;

        // Define parallax layers with their elements and factors
        const layers = [
          { el: document.querySelector('.hero-tag'), factor: 0.015 },
          { el: document.querySelector('.hero-title'), factor: 0.030 },
          { el: document.querySelector('.hero-subtitle'), factor: 0.020 },
          { el: document.querySelector('.hero-desc'), factor: 0.012 },
        ].filter(layer => layer.el !== null);

        // Initialize current and target values for each layer
        layers.forEach(layer => {
          layer.currentX = 0;
          layer.currentY = 0;
          layer.targetX = 0;
          layer.targetY = 0;
        });

        let mouseX = 0, mouseY = 0;

        // Listen for mouse movement
        document.addEventListener('mousemove', (e) => {
          mouseX = e.clientX - window.innerWidth / 2;
          mouseY = e.clientY - window.innerHeight / 2;
          layers.forEach(layer => {
            layer.targetX = mouseX * layer.factor;
            layer.targetY = mouseY * layer.factor;
          });
        });

        // Reset targets when mouse leaves window
        document.addEventListener('mouseleave', () => {
          layers.forEach(layer => {
            layer.targetX = 0;
            layer.targetY = 0;
          });
        });

        // RAF loop with lerp
        function tick() {
          layers.forEach(layer => {
            layer.currentX += (layer.targetX - layer.currentX) * 0.072;
            layer.currentY += (layer.targetY - layer.currentY) * 0.072;
            layer.el.style.transform = 'translate(' + layer.currentX.toFixed(2) + 'px, ' + layer.currentY.toFixed(2) + 'px)';
          });
          requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      })();
    </script>
  </body>
</html>
