---
import Header from "../components/Header.astro";
import FeaturedPost from "../components/FeaturedPost.astro";
import PostRow from "../components/PostRow.astro";
import { getPosts } from "../lib/posts";
import "../styles/global.css";

const posts = getPosts();
const featured = posts[0];
const rest = posts.slice(1, 7);
const showViewAll = posts.length > 6;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ST Zhang</title>
    <meta
      name="description"
      content="ST Zhang's personal blog about AI, technology, notes, and building on the internet."
    />
  </head>

  <body>
    <div class="site-shell">
      <Header />

      <main class="page-main">
        <section class="hero">
          <div class="hero-copy">
            <h1 data-no-translate>ST Zhang</h1>

            <p class="hero-kicker">AI · Tech · Notes</p>

            <p class="hero-description">
              Writing, building, and thinking on the internet.
            </p>
          </div>

          <aside class="hero-aside" data-no-translate>
            <span class="quote-label" id="daily-quote-label">Daily quote</span>
            <p class="quote-text" id="daily-quote-text">
              The obstacle is the way.
            </p>
            <p class="quote-source" id="daily-quote-source">
              Marcus Aurelius · Meditations
            </p>
          </aside>
        </section>

        <section id="writing" class="writing-section">
          <div class="section-heading">
            <h2>Writing</h2>
            {showViewAll && <a href="/writing">View all →</a>}
          </div>

          {
            featured ? (
              <>
                <FeaturedPost post={featured} />

                {
                  rest.length > 0 && (
                    <div class="post-list">
                      {rest.map((post) => <PostRow post={post} />)}
                    </div>
                  )
                }
              </>
            ) : (
              <p class="empty-state">No posts yet.</p>
            )
          }
        </section>

        <section class="topics-section">
          <div class="section-heading">
            <h2>Topics</h2>
          </div>

          <div class="topic-layout">
            <div class="topic-panel topic-panel-large">
              <h3>AI</h3>
              <p>
                Notes on models, tools, workflows, automation, and how AI changes
                the way people build and think.
              </p>
            </div>

            <div class="topic-stack">
              <div class="topic-panel">
                <h3>Tech</h3>
                <p>
                  Practical writing about software, web infrastructure, domains,
                  deployment, and the small systems behind personal projects.
                </p>
              </div>

              <div class="topic-panel">
                <h3>Notes</h3>
                <p>
                  Short observations, reading notes, decisions, and personal logs
                  that do not need to become polished essays.
                </p>
              </div>
            </div>
          </div>
        </section>
      </main>

      <footer class="site-footer">
        <span>© {new Date().getFullYear()} ST Zhang</span>

        <a
          href="https://github.com/ZhangSteven0819"
          target="_blank"
          rel="noreferrer"
          aria-label="GitHub profile"
          data-no-translate
        >
          <svg
            class="github-icon"
            viewBox="0 0 24 24"
            aria-hidden="true"
            fill="currentColor"
          >
            <path
              d="M12 2C6.48 2 2 6.58 2 12.22c0 4.52 2.87 8.35 6.84 9.7.5.1.68-.22.68-.49v-1.88c-2.78.62-3.36-1.22-3.36-1.22-.45-1.18-1.11-1.49-1.11-1.49-.91-.64.07-.63.07-.63 1 .07 1.53 1.06 1.53 1.06.9 1.57 2.36 1.12 2.94.86.09-.67.35-1.12.63-1.38-2.22-.26-4.56-1.14-4.56-5.06 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05A9.35 9.35 0 0 1 12 6.95c.85 0 1.7.12 2.5.34 1.9-1.33 2.74-1.05 2.74-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.8-4.57 5.05.36.32.68.95.68 1.92v2.84c0 .27.18.59.69.49A10.04 10.04 0 0 0 22 12.22C22 6.58 17.52 2 12 2Z"
            />
          </svg>
          GitHub
        </a>
      </footer>
    </div>
  </body>
</html>