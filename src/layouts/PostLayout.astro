---
const {
  title = "Untitled",
  description = "",
  publishDate = "",
  tags = [],
} = Astro.props.frontmatter || {};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · ST Zhang</title>
    <meta name="description" content={description || title} />
  </head>

  <body>
    <div class="site-shell">
      <header class="nav">
        <a class="brand" href="/">ST Zhang</a>
        <nav>
          <a href="/">Home</a>
          <a href="/admin/">Write</a>
          <a href="https://github.com/ZhangSteven0819" target="_blank">GitHub</a>
        </nav>
      </header>

      <main class="article-wrap">
        <a class="back" href="/">← Back</a>

        <article class="article">
          <div class="eyebrow">Essay</div>
          <h1>{title}</h1>

          {
            description && (
              <p class="description">{description}</p>
            )
          }

          <div class="meta">
            {publishDate && <span>{publishDate}</span>}
            {
              tags?.length > 0 && (
                <span>{tags.join(" · ")}</span>
              )
            }
          </div>

          <div class="content">
            <slot />
          </div>
        </article>
      </main>
    </div>
  </body>
</html>

<style>
  :root {
    color-scheme: light dark;
    --bg: #fafafa;
    --text: #171717;
    --muted: #737373;
    --soft: #a3a3a3;
    --card: #ffffff;
    --line: #e5e5e5;
    --accent: #111111;
    --chip: #f5f5f5;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #09090b;
      --text: #f5f5f5;
      --muted: #a1a1aa;
      --soft: #71717a;
      --card: #111113;
      --line: #27272a;
      --accent: #ffffff;
      --chip: #18181b;
    }
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  .site-shell {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
  }

  .nav {
    height: 76px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--line);
  }

  .brand {
    color: var(--text);
    text-decoration: none;
    font-weight: 750;
    letter-spacing: -0.04em;
    font-size: 20px;
  }

  nav {
    display: flex;
    gap: 18px;
  }

  nav a,
  .back {
    color: var(--muted);
    text-decoration: none;
    font-size: 14px;
  }

  nav a:hover,
  .back:hover {
    color: var(--text);
  }

  .article-wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 72px 0 96px;
  }

  .article {
    margin-top: 28px;
  }

  .eyebrow {
    color: var(--muted);
    font-size: 13px;
    font-weight: 650;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 18px;
  }

  h1 {
    margin: 0;
    font-size: clamp(44px, 7vw, 76px);
    line-height: 0.95;
    letter-spacing: -0.075em;
  }

  .description {
    margin: 24px 0 0;
    color: var(--muted);
    font-size: 21px;
    line-height: 1.55;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
    color: var(--soft);
    font-size: 14px;
  }

  .meta span {
    border: 1px solid var(--line);
    background: var(--chip);
    border-radius: 999px;
    padding: 7px 11px;
  }

  .content {
    margin-top: 56px;
    font-size: 18px;
    line-height: 1.82;
    color: var(--text);
  }

  .content :global(p) {
    margin: 0 0 1.35em;
  }

  .content :global(h2) {
    margin: 2.2em 0 0.8em;
    font-size: 32px;
    line-height: 1.15;
    letter-spacing: -0.04em;
  }

  .content :global(h3) {
    margin: 2em 0 0.7em;
    font-size: 24px;
    letter-spacing: -0.03em;
  }

  .content :global(a) {
    color: var(--text);
    text-decoration-thickness: 1px;
    text-underline-offset: 4px;
  }

  .content :global(blockquote) {
    margin: 2em 0;
    padding-left: 20px;
    border-left: 2px solid var(--text);
    color: var(--muted);
    font-style: italic;
  }

  .content :global(code) {
    background: var(--chip);
    border: 1px solid var(--line);
    border-radius: 7px;
    padding: 2px 6px;
    font-size: 0.9em;
  }

  .content :global(pre) {
    overflow-x: auto;
    padding: 18px;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: var(--card);
  }

  .content :global(pre code) {
    background: transparent;
    border: 0;
    padding: 0;
  }

  @media (max-width: 720px) {
    .nav {
      height: auto;
      padding: 22px 0;
      align-items: flex-start;
      flex-direction: column;
      gap: 14px;
    }

    .article-wrap {
      padding: 48px 0 72px;
    }

    nav {
      gap: 14px;
    }
  }
</style>
