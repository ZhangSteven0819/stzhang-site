---
import Header from "../components/Header.astro";
import Tag from "../components/Tag.astro";
import { formatFullDate } from "../lib/posts";
import "../styles/global.css";

const frontmatter = Astro.props.frontmatter || {};

const {
  title = "Untitled",
  description = "",
  publishDate = "",
  tags = [],
} = frontmatter;

const tagList = Array.isArray(tags) ? tags : [];
const displayDate = publishDate ? formatFullDate(String(publishDate)) : "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · ST Zhang</title>
    <meta name="description" content={description || title} />
  </head>

  <body>
    <div class="site-shell">
      <Header current="writing" />

      <main class="article-page">
        <header class="article-header">
          {
            tagList.length > 0 && (
              <div class="article-tags">
                {tagList.map((tag) => <Tag label={tag} />)}
              </div>
            )
          }

          <h1>{title}</h1>

          {displayDate && <p class="article-date">{displayDate}</p>}

          {
            description && (
              <p class="article-description">{description}</p>
            )
          }

          <div class="article-divider"></div>
        </header>

        <article class="article-content">
          <slot />
        </article>

        <footer class="article-footer">
          <a href="/writing">← Back to writing</a>
        </footer>
      </main>
    </div>
  </body>
</html>